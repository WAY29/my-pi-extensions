{
  "name": "pi-sandbox",
  "version": "0.4.3",
  "description": "OS-level sandboxing for pi bash commands",
  "type": "module",
  "pi": {
    "extensions": ["index.js"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carderne/pi-sandbox.git"
  },
  "author": "Chris Arderne <chris@rdrn.me>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carderne/pi-sandbox/issues"
  },
  "homepage": "https://github.com/carderne/pi-sandbox",
  "scripts": {
    "build": "node scripts/build.mjs",
    "fmt": "oxfmt index.ts src",
    "lint": "oxlint src",
    "check": "tsc --noEmit",
    "all": "npm run fmt && npm run lint && npm run check",
    "ci:fmt": "oxfmt --check index.ts src",
    "ci:lint": "npm run lint",
    "ci:check": "npm run check"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@carderne/sandbox-runtime": "^0.0.49",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^24",
    "esbuild": "^0.27.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "lodash-es": ">=4.18.1"
  }
}
